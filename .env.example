# Required
WALLET_PRIVATE_KEY=0x...
RPC_URL=https://mainnet.base.org

# Strategy Mode: conservative | balanced | aggressive | volume_play
STRATEGY_MODE=aggressive

# Position & Risk
MAX_POSITION_PERCENT=3
MAX_TOTAL_POSITIONS=5
MAX_TOTAL_EXPOSURE=25
TAKE_PROFIT_PERCENT=7
STOP_LOSS_PERCENT=-5
MAX_SLIPPAGE_BPS=200

# Bonus Signals (true/false)
ENABLE_CURVE_SIGNAL=true
ENABLE_MARCO_SIGNAL=true
