# ─── Required ───────────────────────────────────────────
WALLET_PRIVATE_KEY=0x...
RPC_URL=https://mainnet.base.org

# ─── Strategy Mode ──────────────────────────────────────
# Pilih: conservative | balanced | aggressive | volume_play
STRATEGY_MODE=aggressive

# ─── Position Sizing & Compounding ──────────────────────
MAX_POSITION_PERCENT=3          # % saldo per posisi
MAX_TOTAL_POSITIONS=5           # maksimum posisi simultan
MAX_TOTAL_EXPOSURE=80           # % total saldo yang boleh terpakai

# ─── Take Profit / Stop Loss ────────────────────────────
TAKE_PROFIT_PERCENT=7           # % profit target
STOP_LOSS_PERCENT=-5            # % batas rugi (nilai negatif)

# ─── Slippage ───────────────────────────────────────────
MAX_SLIPPAGE_BPS=200            # basis poin (200 = 2%)

# ─── Dashboard (Opsional, untuk loadflux) ──────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=password_rahasia
