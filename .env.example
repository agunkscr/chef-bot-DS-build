# ─── Required ───────────────────────────────────────────
WALLET_PRIVATE_KEY=0x...
RPC_URL=https://mainnet.base.org

# ─── Strategy Mode ──────────────────────────────────────
# Pilih: conservative | balanced | aggressive | volume_play | adaptive
STRATEGY_MODE=adaptive

# ─── Position Sizing & Compounding ──────────────────────
MAX_POSITION_PERCENT=2          # % saldo per posisi
MAX_TOTAL_POSITIONS=4           # maksimum posisi simultan
MAX_TOTAL_EXPOSURE=20           # % total saldo yang boleh terpakai

# ─── Take Profit / Stop Loss ────────────────────────────
TAKE_PROFIT_PERCENT=7           # % profit target
STOP_LOSS_PERCENT=-5            # % batas rugi (nilai negatif)

# ─── Slippage ───────────────────────────────────────────
MAX_SLIPPAGE_BPS=0              # 0 = auto sesuai mode

# ─── Volume Minimal 24 Jam (dalam CHEF) ────────────────
MIN_VOLUME_24H=0                # 0 = ikut default mode

# ─── Cooldown Setelah Sell (menit) ──────────────────────
COOLDOWN_MINUTES=60             # hindari beli token yang baru dijual

# ─── Mode Adaptive: Skor Minimal ────────────────────────
MIN_SCORE=1                     # makin kecil makin longgar

# ─── Bonus Signals ──────────────────────────────────────
ENABLE_CURVE_SIGNAL=true
ENABLE_MARCO_SIGNAL=false

# ─── Interval Pengecekan ────────────────────────────────
CHECK_INTERVAL_MS=300000        # 5 menit (300000 ms)

# ─── Dashboard (Opsional) ───────────────────────────────
DASHBOARD_USER=admin
DASHBOARD_PASS=password_rahasia